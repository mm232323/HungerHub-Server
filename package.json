{
  "name": "api-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#supabase": {
      "types": "./src/lib/supabase.ts",
      "default": "./dist/src/lib/supabase.js"
    },
    "#api-zod": {
      "types": "./src/api-zod/index.ts",
      "default": "./dist/src/api-zod/index.js"
    }
  },
  "scripts": {
    "dev": "npm run build && npm run start",
    "build": "tsc",
    "start": "tsx src/handler.ts",
    "dev:watch": "tsx watch src/handler.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clerk/express": "^2.1.15",
    "@clerk/shared": "^4.10.2",
    "@supabase/supabase-js": "^2.105.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.30.0",
    "express": "^5",
    "http-proxy-middleware": "^4.0.0",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "^4.22.1"
  }
}